rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSeller() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/shopOwners/$(request.auth.uid));
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isOrderCustomer() {
      return isSignedIn() && (
        resource.data.customerId == request.auth.uid ||
        (resource.data.customerEmail != null &&
          request.auth.token.email != null &&
          resource.data.customerEmail == request.auth.token.email)
      );
    }

    function isOrderSeller() {
      return isSeller() && resource.data.shopId == request.auth.uid;
    }

    // ── User profiles ──────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Profile mirror ─────────────────────────────────────────────────────────
    match /profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // ── Orders ─────────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Customers: read by customerId or customerEmail (legacy orders)
      // Sellers: read/update only their shop's orders
      allow create: if isSignedIn();
      allow read: if isOrderCustomer() || isOrderSeller() || isAdmin();
      allow update: if isOrderSeller() || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Shops (public catalog) ─────────────────────────────────────────────────
    match /shops/{shopId} {
      allow read: if true;                            // public read
      allow write: if isOwner(shopId) || isAdmin();  // only the owning seller
    }

    // ── Shop owners / sellers ──────────────────────────────────────────────────
    match /shopOwners/{sellerId} {
      allow read: if true;                             // public — shop catalog is visible to everyone
      allow create: if isAdmin();
      allow update: if isOwner(sellerId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Admins collection ──────────────────────────────────────────────────────
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── System settings ────────────────────────────────────────────────────────
    match /systemSettings/{docId} {
      allow read: if true;      // public — needed before auth (maintenance mode check)
      allow write: if isAdmin();
    }

    // ── Audit logs ─────────────────────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();   // any authenticated action can create a log
      allow update, delete: if false;  // logs are immutable
    }

    // ── Notifications ──────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (
        resource.data.recipientId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.recipientId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── Seller invitations ─────────────────────────────────────────────────────
    match /sellerInvitations/{inviteId} {
      allow read: if true;       // needed for invitation acceptance link
      allow write: if isAdmin();
    }

    // ── Coupons ────────────────────────────────────────────────────────────────
    match /coupons/{couponId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Coupon Usage ───────────────────────────────────────────────────────────
    match /couponUsage/{usageId} {
      allow read, write: if isAdmin();
    }

    // ── Payout Requests ───────────────────────────────────────────────────────
    match /payoutRequests/{requestId} {
      allow read, write: if isAdmin() || isSeller(); // Sellers can see/create their own, admins manage all
    }

    // ── Sponsors ───────────────────────────────────────────────────────────────
    match /sponsors/{sponsorId} {
      allow read: if isOwner(sponsorId) || isAdmin();
      allow create: if isOwner(sponsorId);
      allow update: if isOwner(sponsorId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Campaigns ──────────────────────────────────────────────────────────────
    match /campaigns/{campaignId} {
      allow read: if isSignedIn() && (resource.data.sponsorId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.sponsorId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.sponsorId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.sponsorId == request.auth.uid || isAdmin());
    }

    // ── Ad Impressions ─────────────────────────────────────────────────────────
    match /adImpressions/{impressionId} {
      allow read: if isSignedIn() && (resource.data.sponsorId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── Deny everything else ───────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}